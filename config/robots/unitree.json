{
  "id": "unitree",
  "label": "Unitree Go2 EDU",
  "model": "Go2 EDU",
  "repo": "unitreerobotics/unitree_ros",
  "description": "Unitree Go2 EDU URDF from the official unitree_ros repository.",
  "urdf": {
    "source": "unitreerobotics/unitree_ros",
    "path": "vendor/unitree_ros/robots/go2_description/urdf/go2_description.urdf",
    "rootFrame": "base",
    "frameAliases": {
      "base_link": "base"
    }
  },
  "topics": {
    "jointStates": "/joint_states",
    "tf": "/tf",
    "tfStatic": "/tf_static",
    "odom": "/odom",
    "cmdVel": "/cmd_vel",
    "pointCloud": "/camera/depth/color/points",
    "depthCameraInfo": "/camera/depth/camera_info",
    "missionEvents": "/fms/mission_events",
    "lowState": "/lowstate",
    "lowStateLf": "/lf/lowstate"
  },
  "depthSensor": {
    "label": "RealSense D435i depth",
    "pointCloudTopic": "/camera/depth/color/points",
    "preferredFrames": [
      "camera_depth_optical_frame",
      "camera_color_optical_frame",
      "realsense_depth_optical_frame"
    ],
    "fallbackParentFrame": "base",
    "fallbackOpticalFrame": "camera_depth_optical_frame",
    "fallbackOrigin": [0.28, 0.0, 0.18],
    "fallbackRpy": [0.0, 0.2618, 0.0],
    "fallbackDevice": "/dev/video4",
    "fallbackResolution": [640, 360],
    "fallbackFps": 30,
    "depthRgbCameraId": "realsense_rgb",
    "depthViewMode": "rgb_overlay",
    "depthViewOverlayAlpha": 0.42,
    "depthStreamFps": 15,
    "assistUpdateInterval": 0.2,
    "geometryUpdateInterval": 0.7,
    "depthScaleMeters": 0.001,
    "horizontalFovDeg": 87,
    "verticalFovDeg": 58,
    "nearMeters": 0.18,
    "farMeters": 3.0,
    "focusFarMeters": 1.05,
    "depthViewFarMeters": 1.4,
    "maxPoints": 36000,
    "surfaceStep": 3,
    "surfaceMaxDepthDelta": 0.12,
    "holeFill": true,
    "holeFillMedian": 5,
    "spatialFilter": true,
    "bilateralDiameter": 5,
    "bilateralSigmaColorMeters": 0.05,
    "bilateralSigmaSpace": 5.0,
    "temporalAlpha": 0.45,
    "temporalMaxDeltaMeters": 0.18,
    "componentFilter": true,
    "componentMinPixels": 80,
    "componentOpenIterations": 1,
    "componentCloseIterations": 1,
    "objectSegmentation": true,
    "roiXMeters": [-0.55, 0.55],
    "roiYMeters": [-0.45, 0.45],
    "planeRemoval": true,
    "planeDistanceThreshold": 0.025,
    "planeIterations": 140,
    "planeSamplePoints": 6500,
    "planeMinInliers": 900,
    "clusterMinPixels": 140,
    "clusterMaxPixels": 90000,
    "clusterMaxObjects": 8,
    "clusterCloseIterations": 2,
    "clusterOpenIterations": 1,
    "clusterDropBorder": true,
    "clusterDropLargeBorderRatio": 0.28,
    "assistDesiredMeters": 0.45,
    "assistToleranceMeters": 0.12,
    "assistCenterX": 0.5,
    "assistCenterY": 0.52,
    "assistRoiWidth": 0.24,
    "assistRoiHeight": 0.34,
    "assistOverlayResolution": [640, 360]
  },
  "lowStateJointNames": [
    "FL_hip_joint",
    "FL_thigh_joint",
    "FL_calf_joint",
    "FR_hip_joint",
    "FR_thigh_joint",
    "FR_calf_joint",
    "RL_hip_joint",
    "RL_thigh_joint",
    "RL_calf_joint",
    "RR_hip_joint",
    "RR_thigh_joint",
    "RR_calf_joint"
  ],
  "defaultJointPositions": {
    "FL_hip_joint": 0.0,
    "FL_thigh_joint": 0.78,
    "FL_calf_joint": -1.52,
    "FR_hip_joint": 0.0,
    "FR_thigh_joint": 0.78,
    "FR_calf_joint": -1.52,
    "RL_hip_joint": 0.0,
    "RL_thigh_joint": 0.78,
    "RL_calf_joint": -1.52,
    "RR_hip_joint": 0.0,
    "RR_thigh_joint": 0.78,
    "RR_calf_joint": -1.52
  },
  "cameraSlots": [
    "logitech_front",
    "logitech_rear",
    "realsense_rgb",
    "aux_4"
  ]
}
